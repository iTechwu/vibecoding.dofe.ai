# ============================================
# API / SSO
# ============================================
NEXT_PUBLIC_SERVER_BASE_URL=http://127.0.0.1:13100
VIBECODING_INTERNAL_API_URL=http://127.0.0.1:13100
NEXT_PUBLIC_SSO_BASE_URL=http://127.0.0.1:3100
# Keep this SSO tier aligned with API SSO_ISSUER / SSO_API_URL for real E2E.
# The API callback URL should be registered in SSO:
#   http://127.0.0.1:13100/auth/oidc/callback

# ============================================
# Brand
# ============================================
NEXT_PUBLIC_BRAND_NAME=DoFe.AI
NEXT_PUBLIC_BRAND_LOGO=/logo.svg
NEXT_PUBLIC_BRAND_TITLE=DoFe.AI | Do For Employee · Enterprise · Empowerment
NEXT_PUBLIC_BRAND_DESCRIPTION=DoFe.AI — Do For Employee · Do For Enterprise · Do For Empowerment. A distributed AI execution engine: API gateway, model routing, usage analytics, and intelligent ops console.

# ============================================
# Version / analytics
# ============================================
# NEXT_PUBLIC_API_VERSION=1
# NEXT_PUBLIC_APP_BUILD=
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=/analytics

# ============================================
# Loops
# ============================================
# Server-side default repo shown by /loops/new.
# NEXT_PUBLIC_LOOPS_DEFAULT_REPO=/absolute/path/to/workspace

# ============================================
# TikTok OAuth (server-side only)
# ============================================
# TIKTOK_ENDPOINT_OAUTH=https://www.tiktok.com/v2/auth/authorize/
# TIKTOK_API_ENDPOINT=https://open.tiktokapis.com
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_AUTH_SCOPES=user.info.basic
# TIKTOK_REDIRECT_URI=http://127.0.0.1:3003/auth/tiktok/callback

# ============================================
# E2E tests
# ============================================
# Set to 1 only when real SSO credentials and web/api/sso services are available.
# E2E_WEB_BASE_URL=http://127.0.0.1:3003
# SSO_E2E_ENABLED=0
# E2E_API_ORIGIN=http://127.0.0.1:13100
# E2E_SSO_ORIGIN=http://127.0.0.1:3100
# E2E_SSO_LOGIN_ORIGIN=http://127.0.0.1:3000
# E2E_CALLBACK_URL=/
# E2E_LOGIN_PATH=/login
# E2E_SSO_EMAIL=
# E2E_SSO_MOBILE=
# E2E_SSO_PASSWORD=
