# ============================================
# 运行环境
# ============================================
NODE_ENV=dev

# ============================================
# 基础设施
# ============================================
BASE_HOST=127.0.0.1
# PostgreSQL（读写分离，生产环境可配置不同实例）
DATABASE_URL=postgresql://your_user:your_password@127.0.0.1:5432/your_db?schema=public&timezone=Asia/Shanghai
READ_DATABASE_URL=postgresql://your_user:your_password@127.0.0.1:5432/your_db?schema=public&timezone=Asia/Shanghai

# Redis（db 编号说明：0=默认，1=session，2=业务缓存）
REDIS_URL=redis://:your_redis_password@127.0.0.1:6379/2

# RabbitMQ
RABBITMQ_URL=amqp://your_user:your_password@127.0.0.1:5672/your_vhost
RABBITMQ_EVENTS_URL=amqp://your_user:your_password@${BASE_HOST}:5672/your_events_vhost
# 设为 true 时，RabbitMQ 不可用不会阻塞应用启动
RABBITMQ_OPTIONAL=true

# ============================================
# 密钥配置
# ============================================
# NOTE: 核心密钥已迁移至 keys/config.json，请参考 keys/config.json 配置以下字段：
#   JWT_SECRET / CRYPTO_KEY / CRYPTO_IV / ENCRYPTION_KEY / ADMIN_REGISTER_SECRET
# 该文件被 .gitignore 排除，不会提交到仓库

# ============================================
# 外部服务（可选）
# ============================================
# 阿里云 SMS
# ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_secret

# 火山引擎（TTS / ASR）
# VOLCENGINE_ACCESS_KEY=your_access_key
# VOLCENGINE_SECRET_KEY=your_secret_key

# AWS（S3 文件存储）
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your_bucket
