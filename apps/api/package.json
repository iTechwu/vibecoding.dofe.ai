{
  "name": "@repo/api",
  "version": "0.0.1",
  "description": "DofeAI NestJS Backend",
  "author": "techwu",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "prisma generate && node scripts/link-prisma.js",
    "build": "prisma format && prisma generate && node scripts/link-prisma.js && node scripts/generate-db-crud.js && cross-env NODE_OPTIONS='--max-old-space-size=8192' nest build",
    "format": "prettier --write \"src/**/*.ts\" \"libs/**/*.ts\"",
    "start": "cross-env NODE_ENV=dev MICRO_SERVER_NAME=api PROJECT_ROOT=\"$(pwd)\" NODE_EXTRA_CA_CERTS=/Users/techwu/Documents/codes/dofe.ai/docker-helm.dofe.ai/nginx/certs/dofe.local.dofe.ai.mkcert-rootCA.pem NODE_OPTIONS=\"-r ./scripts/resolve-dofe-ext.js\" node dist/main",
    "dev": "cross-env NODE_ENV=dev MICRO_SERVER_NAME=api PROJECT_ROOT=\"$(pwd)\" NODE_EXTRA_CA_CERTS=/Users/techwu/Documents/codes/dofe.ai/docker-helm.dofe.ai/nginx/certs/dofe.local.dofe.ai.mkcert-rootCA.pem NODE_OPTIONS=\"-r ./scripts/resolve-dofe-ext.js\" nest start --watch --preserveWatchOutput",
    "debug": "cross-env NODE_ENV=test MICRO_SERVER_NAME=api PROJECT_ROOT=\"$(pwd)\" NODE_OPTIONS=\"-r ./scripts/resolve-dofe-ext.js\" nest start --debug --watch",
    "start:test": "cross-env NODE_ENV=test MICRO_SERVER_NAME=api PROJECT_ROOT=\"$(pwd)\" NODE_OPTIONS=\"-r ./scripts/resolve-dofe-ext.js\" node dist/main",
    "prod:cn": "cross-env NODE_ENV=prod MICRO_SERVER_NAME=api PROJECT_ROOT=\"$(pwd)\" NODE_OPTIONS=\"-r ./scripts/resolve-dofe-ext.js\" node dist/main",
    "prod:us": "cross-env NODE_ENV=produs MICRO_SERVER_NAME=api PROJECT_ROOT=\"$(pwd)\" NODE_OPTIONS=\"-r ./scripts/resolve-dofe-ext.js\" node dist/main",
    "prod:ap": "cross-env NODE_ENV=prodap MICRO_SERVER_NAME=api PROJECT_ROOT=\"$(pwd)\" NODE_OPTIONS=\"-r ./scripts/resolve-dofe-ext.js\" node dist/main",
    "lint": "eslint \"{src,libs}/**/*.ts\"",
    "lint:fix": "eslint \"{src,libs}/**/*.ts\" --fix",
    "type-check": "tsc -p tsconfig.type-check.json",
    "db:migrate:diff": "node scripts/generate-migration-diff.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.config.ts",
    "clean": "rimraf dist",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push --skip-generate",
    "db:generate": "prisma generate && node scripts/link-prisma.js && node scripts/generate-db-crud.js",
    "generate:db-crud-cli": "dofe-prisma-crud generate --schema apps/api/prisma/schema.prisma --out apps/api/generated/db/modules --index apps/api/generated/db/index.ts",
    "generate:enums-cli": "dofe-prisma-crud generate enums --schema apps/api/prisma/schema.prisma --out packages/contracts/src/schemas/prisma-enums.generated.ts",
    "db:format": "prisma format",
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "validate:versions": "ts-node scripts/validate-api-versions.ts"
  },
