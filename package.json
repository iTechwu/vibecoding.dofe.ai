{
  "name": "vibecoding.dofe.ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "kill:dev": "lsof -ti:3101 | xargs kill -9 2>/dev/null && echo \"done\" || echo \"no process on port 3101\"",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@repo/web",
    "dev:api": "turbo run dev --filter=@repo/api",
    "build": "turbo run build --filter=./apps/* --filter=./packages/*",
    "build:web": "turbo run build --filter=@repo/web",
    "build:api": "turbo run build --filter=@repo/api",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:web": "turbo run lint --filter=@repo/web",
    "lint:api": "turbo run lint --filter=@repo/api",
    "type-check": "turbo run type-check --filter=./apps/* --filter=./packages/*",
    "test": "turbo run test",
    "test:web": "turbo run test --filter=@repo/web",
    "test:api": "turbo run test --filter=@repo/api",
    "test:packages": "turbo run test --filter=@repo/validators --filter=@repo/utils --filter=@repo/contracts",
    "test:cov": "turbo run test:cov",
    "test:e2e": "turbo run test:e2e --filter=@repo/web",
    "db:format": "turbo run db:format --filter=@repo/api",
    "db:generate": "turbo run db:generate --filter=@repo/api",
    "db:migrate:dev": "turbo run db:migrate:dev --filter=@repo/api",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@repo/api",
    "db:push": "turbo run db:push --filter=@repo/api",
    "clean": "turbo run clean && rm -rf node_modules",
    "generate:enums": "node scripts/generate-prisma-enums.js",
    "generate:i18n-errors": "ts-node scripts/generate-i18n-errors.ts",
    "export-scaffold": "node scripts/export-scaffold-for-create.js",
    "publish:scaffold": "bash scripts/publish-create-dofe-ai.sh",
    "create-scaffold": "node packages/create-dofe-ai/cli.js",
    "prebuild": "pnpm generate:enums",
    "check:architecture": "bash scripts/check-architecture.sh",
    "check:list-contracts": "node scripts/check-list-response-schemas.js",
    "check:sensitive-logs": "node scripts/check-sensitive-logs.js",
    "check:utils-hygiene": "node scripts/check-utils-hygiene.js",
    "quality:gate": "pnpm check:architecture && pnpm check:list-contracts && pnpm check:sensitive-logs && pnpm check:utils-hygiene && pnpm type-check",
    "prepare": "husky || true",
    "kill:api": "lsof -ti:13100 | xargs kill -9 2>/dev/null && echo \"done\" || echo \"no process on port 13100\"",
    "kill:web": "lsof -ti:3000 | xargs kill -9 2>/dev/null && echo \"done\" || echo \"no process on port 3000\"",
    "openssl:random": "openssl rand -hex 32"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "openai": "^6.17.0",
      "glob": "^13.0.1",
      "rimraf": "^6.0.1",
      "rxjs": "7.8.2",
      "punycode": "^2.3.1",
      "@dofe/infra-common": "^0.1.55",
      "@dofe/infra-contracts": "^0.1.55",
      "@dofe/infra-utils": "^0.1.55",
      "@dofe/infra-redis": "^0.1.55",
      "@dofe/infra-prisma": "^0.1.55",
      "@dofe/infra-clients": "^0.1.55",
      "@dofe/infra-rabbitmq": "^0.1.55",
      "@dofe/infra-shared-services": "^0.1.55",
      "@dofe/infra-docker": "^0.1.55",
      "@dofe/infra-jwt": "^0.1.55",
      "@dofe/infra-shared-db": "^0.1.55",
      "@dofe/infra-i18n": "^0.1.55"
    },
    "patchedDependencies": {
      "eslint-plugin-react@7.37.5": "patches/eslint-plugin-react@7.37.5.patch"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "openai": "6",
        "rxjs": "7.8.2",
        "uuid": "11",
        "bcrypt": "6",
        "music-metadata": "7 || 11",
        "amqplib": "0",
        "nodemailer": "7",
        "@alicloud/dysmsapi20170525": "4",
        "eslint": "10",
        "react": "19",
        "class-validator": "0.15",
        "dotenv": "17",
        "dotenv-expand": "13",
        "moment-timezone": "0.6"
      },
      "ignoreMissing": [
        "openai",
        "@swc/core",
        "@swc/wasm",
        "@swc-node/register",
        "node-notifier",
        "ts-node",
        "encoding",
        "webpack-cli"
      ]
    },
    "onlyBuiltDependencies": [
      "@alicloud/openapi-core",
      "@google/genai",
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/engines",
      "@scarf/scarf",
      "@swc/core",
      "bcrypt",
      "core-js-pure",
      "cpu-features",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "protobufjs",
      "sharp",
      "ssh2",
      "tos-crc64-js",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@swc/core": "^1.15.41",
    "zod": "^4.4.3"
  }
}
