# ============================================
# 运行环境
# ============================================
NODE_ENV=dev
BASE_HOST=127.0.0.1

# ========== 数据库（必需）==========
DATABASE_URL=postgresql://dofe:pG8k4M2nX9vL@127.0.0.1:5432/vibecoding_dofe?schema=public&timezone=Asia/Shanghai
READ_DATABASE_URL=postgresql://dofe:pG8k4M2nX9vL@127.0.0.1:5432/vibecoding_dofe?schema=public&timezone=Asia/Shanghai

# ========== 缓存（必需）==========
REDIS_URL=redis://:dYop914G7k5S@127.0.0.1:6379/2

# ========== SSO（必需，sso.dofe.ai 为唯一真源）==========
SSO_API_URL=http://127.0.0.1:3100
SSO_INTERNAL_API_URL=http://127.0.0.1:3100
SSO_ISSUER=http://127.0.0.1:3100
SSO_CLIENT_ID=vibecoding-dofe-ai
SSO_CLIENT_SECRET=your-vibecoding-client-secret-from-sso
SSO_SERVICE_NAME=vibecoding.dofe.ai
INTERNAL_API_SECRET=your-internal-api-secret-from-sso

# ========== 消息队列 ==========
RABBITMQ_URL=amqp://dofe:N051Gym68Ul3@127.0.0.1:5672/vibecoding_dofe
RABBITMQ_OPTIONAL=true

# ============================================
# 密钥配置
# ============================================
# NOTE: 核心密钥已迁移至 keys/config.json，请参考 keys/config.json 配置以下字段：
#   JWT_SECRET / CRYPTO_KEY / CRYPTO_IV / ENCRYPTION_KEY / ADMIN_REGISTER_SECRET
# 该文件被 .gitignore 排除，不会提交到仓库

# ============================================
# 外部服务（可选）
# ============================================
# 阿里云 SMS
# ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_secret

# 火山引擎（TTS / ASR）
# VOLCENGINE_ACCESS_KEY=your_access_key
# VOLCENGINE_SECRET_KEY=your_secret_key

# AWS（S3 文件存储）
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your_bucket
