generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma-client"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

// ============================================================================
// User System - 用户系统
// ============================================================================
enum SexType {
  UNKNOWN
  MALE
  FEMALE

  @@map("sex_type")
}

model UserInfo {
  id           String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ssoSub       String? @unique @map("sso_sub") @db.VarChar(255) /// SSO 用户唯一标识（sso.dofe.ai 的 user.id）
  nickname     String  @default("") @db.VarChar(255)
  code         String? @unique @db.VarChar(255)
  avatarFileId String? @map("avatar_file_id") @db.Uuid /// 头像文件ID，仅保存 sso.dofe.ai 文件ID引用
  sex          SexType @default(UNKNOWN)
  locale       String? @db.VarChar(20)
  isAdmin      Boolean @default(false) @map("is_admin")
  email        String? @db.VarChar(255) /// 来自 SSO，仅用于 profile 展示
  mobile       String? @db.VarChar(40) /// 来自 SSO，仅用于 profile 展示

  role     String  @default("user")
  isActive Boolean @default(true) @map("is_active")

  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([code])
  @@index([ssoSub])
  @@index([isDeleted, isAdmin])
  @@index([createdAt(sort: Desc)])
  @@index([nickname])
  @@index([avatarFileId])
  @@map("u_user_info")
}

// ============================================================================
// Auth/file source tables are not defined locally.
// Authentication and file metadata are owned only by sso.dofe.ai.
// This project stores SSO user/file identifiers and consumes them via SDK/client APIs.
// ============================================================================

// ============================================================================
// Country Code - 国家代码（用于 IP 信息）
// ============================================================================

model CountryCode {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  continent String    @db.VarChar(10) // us, eu, ap, cn
  code      String    @db.VarChar(10) // 国家代码，如 CN, US, SG
  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@unique([continent, code])
  @@index([continent])
  @@index([code])
  @@map("country_code")
}

// ============================================================================
// Loops - Issue intake and workflow index
// ============================================================================

model LoopIssue {
  id                 String    @id @db.VarChar(80)
  title              String    @db.VarChar(160)
  body               String    @db.Text
  status             String    @db.VarChar(40)
  priority           String    @db.VarChar(10)
  sourceChannel      String    @map("source_channel") @db.VarChar(40)
  sourceKind         String    @default("web_form") @map("source_kind") @db.VarChar(40)
  submitterProvider  String    @default("dev") @map("submitter_provider") @db.VarChar(40)
  submitterId        String    @map("submitter_id") @db.VarChar(120)
  submitterName      String    @map("submitter_name") @db.VarChar(120)
  targetRepo         String    @map("target_repo") @db.Text
  acceptanceCriteria Json      @map("acceptance_criteria")
  rawPayloadRef      String    @map("raw_payload_ref") @db.Text
  createdAt          DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @map("updated_at") @db.Timestamptz(6)
  closedAt           DateTime? @map("closed_at") @db.Timestamptz(6)
  isDeleted          Boolean   @default(false) @map("is_deleted")
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  intakes LoopIssueIntake[]
  state   LoopState?

  @@index([status, updatedAt(sort: Desc)])
  @@index([submitterId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("loop_issue")
}

model LoopIssueIntake {
  id                String    @id @db.VarChar(100)
  issueId           String    @map("issue_id") @db.VarChar(80)
  sourceChannel     String    @map("source_channel") @db.VarChar(40)
  sourceKind        String    @map("source_kind") @db.VarChar(40)
  submitterProvider String    @map("submitter_provider") @db.VarChar(40)
  submitterId       String    @map("submitter_id") @db.VarChar(120)
  submitterName     String    @map("submitter_name") @db.VarChar(120)
  message           String    @db.Text
  rawPayload        Json      @map("raw_payload")
  rawPayloadRef     String    @map("raw_payload_ref") @db.Text
  status            String    @db.VarChar(40)
  createdAt         DateTime  @map("created_at") @db.Timestamptz(6)
  isDeleted         Boolean   @default(false) @map("is_deleted")
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  issue LoopIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([createdAt(sort: Desc)])
  @@map("loop_issue_intake")
}

model LoopState {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  issueId          String    @unique @map("issue_id") @db.VarChar(80)
  phase            String    @db.VarChar(60)
  round            Int       @default(1)
  specVersion      String    @default("v0") @map("spec_version") @db.VarChar(20)
  shardsTotal      Int       @default(0) @map("shards_total")
  shardsDone       Int       @default(0) @map("shards_done")
  shardsInProgress Int       @default(0) @map("shards_in_progress")
  reloopCount      Int       @default(0) @map("reloop_count")
  costTokens       Int       @default(0) @map("cost_tokens")
  costCalls        Int       @default(0) @map("cost_calls")
  paused           Boolean   @default(false)
  finalized        Boolean   @default(false)
  globalVerdict    String?   @map("global_verdict") @db.VarChar(40)
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz(6)
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  issue LoopIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([phase, updatedAt(sort: Desc)])
  @@map("loop_state")
}

model LoopRuntimeBackendPolicy {
  id                String    @id @db.VarChar(120)
  fallbackPolicy    String?   @map("fallback_policy") @db.Text
  costPolicy        String?   @map("cost_policy") @db.Text
  permissionProfile String?   @map("permission_profile") @db.Text
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  isDeleted         Boolean   @default(false) @map("is_deleted")
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([updatedAt(sort: Desc)])
  @@map("loop_runtime_backend_policy")
}

/// 审计日志（参考 models.dofe.ai：业务主动调用 AuditLogService 记录管理操作，不挂全局拦截器）
model AuditLog {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // 操作信息
  action     AuditActionType @map("action")
  resource   String          @map("resource") @db.VarChar(100)
  resourceId String?         @map("resource_id") @db.VarChar(255)

  // 操作者
  actorType String  @map("actor_type") @db.VarChar(50)
  actorId   String? @map("actor_id") @db.VarChar(255)
  teamId    String? @map("team_id") @db.Uuid

  // 操作详情
  changes  Json? @map("changes")
  metadata Json? @map("metadata")

  // 结果
  status   String  @default("success") @map("status") @db.VarChar(20)
  errorMsg String? @map("error_msg") @db.VarChar(500)

  // 请求信息
  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([teamId, createdAt(sort: Desc)])
  @@index([teamId, actorId])
  @@index([action, createdAt(sort: Desc)])
  @@index([resource, resourceId])
  @@index([actorId])
  @@map("audit_logs")
}

/// gstack P1-5: DB-backed persistence for second opinion conflict queue.
model LoopSecondOpinionRecord {
  id               String    @id @db.VarChar(120)
  issueId          String    @map("issue_id") @db.VarChar(80)
  runner           String    @default("claude-code") @db.VarChar(60)
  status           String    @default("pending") @db.VarChar(40)
  summary          String?   @db.Text
  primaryFindings  Json      @default("[]") @map("primary_findings")
  secondaryFindings Json     @default("[]") @map("secondary_findings")
  comparison       Json?     @map("comparison")
  conflicts        Json      @default("[]")
  resolutions      Json      @default("[]")
  fingerprintHash  String?   @map("fingerprint_hash") @db.VarChar(128)
  referencePath    String?   @map("reference_path") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([issueId])
  @@index([status, createdAt(sort: Desc)])
  @@index([fingerprintHash])
  @@map("loop_second_opinion_record")
}

/// gstack P1-4: DB-backed global learning index.
model LoopLearningRecord {
  id                String    @id @db.VarChar(120)
  issueId           String    @map("issue_id") @db.VarChar(80)
  workspaceId       String    @map("workspace_id") @db.VarChar(120)
  repo              String    @db.VarChar(200)
  kind              String    @db.VarChar(60)
  summary           String    @db.Text
  confidence        Float     @default(0.5)
  tags              Json      @default("[]")
  fingerprint       String?   @db.VarChar(128)
  similarLearningIds Json     @default("[]") @map("similar_learning_ids")
  lifecycle         String    @default("active") @db.VarChar(40)
  source            String    @default("loop-finalize") @db.VarChar(60)
  evidenceRefs      Json      @default("[]") @map("evidence_refs")
  reuseCount        Int       @default(0) @map("reuse_count")
  lastUsedAt        DateTime? @map("last_used_at") @db.Timestamptz(6)
  supersededById    String?   @map("superseded_by_id") @db.VarChar(120)
  mergeDecision     String?   @map("merge_decision") @db.VarChar(40)
  mergeDecidedBy    String?   @map("merge_decided_by") @db.VarChar(120)
  mergeDecidedAt    DateTime? @map("merge_decided_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deprecatedAt      DateTime? @map("deprecated_at") @db.Timestamptz(6)
  isDeleted         Boolean   @default(false) @map("is_deleted")
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([workspaceId, lifecycle, updatedAt(sort: Desc)])
  @@index([repo, kind, lifecycle])
  @@index([fingerprint])
  @@index([lifecycle, confidence(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("loop_learning_record")
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ACCESS
  EXPORT
  IMPORT

  @@map("audit_action_type")
}
