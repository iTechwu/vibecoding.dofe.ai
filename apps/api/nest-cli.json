{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "main",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": ".env*",
        "watchAssets": true
      },
      {
        "include": "config.local.yaml",
        "watchAssets": true
      },
      {
        "include": "node_modules/@dofe/infra-i18n/dist/**/*",
        "watchAssets": true
      },
      {
        "include": "keys/config.json",
        "watchAssets": true
      }
    ],
    "builder": "webpack",
    "webpack": true,
    "tsConfigPath": "tsconfig.build.json"
  }
}
