# =============================================================================
# DofeAI REST Client HTTP 文件
# =============================================================================
# 使用 VS Code REST Client 插件可直接执行以下请求
# 端口: 根据 apps/api/config.local.yaml 配置（默认 13100）
# =============================================================================

@baseUrl = http://localhost:13100
@contentType = Content-Type: application/json

# ── 认证 Token（登录后替换）────────────────────────────────────────────────────
@accessToken = YOUR_ACCESS_TOKEN

# =============================================================================
# 健康检查
# =============================================================================

### 系统健康检查
GET {{baseUrl}}/health

# =============================================================================
# 认证接口
# =============================================================================

### 手机密码登录
POST {{baseUrl}}/sign/in/mobile/password
{{contentType}}

{
  "mobile": "YOUR_MOBILE",
  "password": "YOUR_PASSWORD"
}

### 刷新 Token
POST {{baseUrl}}/sign/refresh/token
{{contentType}}
Authorization: Bearer {{accessToken}}

{
  "refreshToken": "YOUR_REFRESH_TOKEN"
}
