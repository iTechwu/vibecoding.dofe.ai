# ============================================
# API 配置
# ============================================
NEXT_PUBLIC_SERVER_BASE_URL=http://localhost:13100
VIBECODING_INTERNAL_API_URL=http://127.0.0.1:13100
NEXT_PUBLIC_SSO_BASE_URL=http://127.0.0.1:3100

# ============================================
# Brand 配置
# ============================================
NEXT_PUBLIC_BRAND_NAME=DoFe.AI
NEXT_PUBLIC_BRAND_LOGO='/logo.svg'
NEXT_PUBLIC_BRAND_TITLE=DoFe.AI | Do For Employee · Enterprise · Empowerment
NEXT_PUBLIC_BRAND_DESCRIPTION=DoFe.AI — Do For Employee · Do For Enterprise · Do For Empowerment. A distributed AI execution engine: API gateway, model routing, usage analytics, and intelligent ops console.
# Optional: 登录页展示的企业愿景/使命/价值观
# NEXT_PUBLIC_BRAND_VISION=成为受世界尊敬的中国企业
# NEXT_PUBLIC_BRAND_MISSION=成就中国智造的全球竞争力
# NEXT_PUBLIC_BRAND_VALUES=

# ============================================
# Version & Analytics（可选）
# ============================================
# NEXT_PUBLIC_API_VERSION=1
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=
# NEXT_PUBLIC_APP_BUILD=

# ============================================
# 安全配置（可选）
# ============================================
# Turnstile CAPTCHA site key（使用 Cloudflare Turnstile 测试密钥可跳过验证）
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Client-side 加密密钥（32 字符，用于前端数据加密）
# NEXT_PUBLIC_ENCRYPTION_KEY=your-32-char-encryption-key
