{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env", "**/config.local.yaml"],
  "globalEnv": [
    "NODE_ENV",
    "DOCKER_HOST",
    "LOOPS_RUNTIME_DETECT_TIMEOUT_MS",
    "LOOPS_WORKSPACE_ROOT",
    "LOOPS_ALLOWED_REPO_ROOTS",
    "DOCKER_REGISTRY_SERVER",
    "DOCKER_REGISTRY_USERNAME",
    "DOCKER_REGISTRY_PASSWORD",
    "MODE_USER_ID",
    "PREVIEW_MODE",
    "PREVIEW_USER_ID",
    "VIBECODING_APP_BASE_URL",
    "VIBECODING_APP_FRONTEND_URL",
    "APP_BASE_URL",
    "APP_FRONTEND_URL",
    "OIDC_APP_BASE_URL",
    "OIDC_APP_FRONTEND_URL",
    "NEXT_PUBLIC_SSO_BASE_URL",
    "SSO_ISSUER",
    "SSO_API_URL",
    "SSO_INTERNAL_API_URL",
    "VIBECODING_INTERNAL_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "inputs": [
        "src/**/*",
        "libs/**/*",
        "generated/**/*",
        "prisma/**/*",
        "package.json",
        "tsconfig*.json"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "test:cov": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "db:format": {
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "outputs": ["generated/**"]
    },
    "db:migrate:dev": {
      "cache": false
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "validate:versions": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
