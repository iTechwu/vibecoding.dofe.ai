# ============================================
# Runtime
# ============================================
NODE_ENV=dev
BASE_HOST=127.0.0.1
# Optional. pnpm scripts already set PROJECT_ROOT="$(pwd)" for the API app.
# PROJECT_ROOT=$(pwd)
# BASE_ZONE=cn
# SWAGGER_ENABLE=false

# ============================================
# Database / cache / queue
# ============================================
DATABASE_URL=postgresql://dofe:password@127.0.0.1:5432/vibecoding_dofe?schema=public&timezone=Asia/Shanghai
READ_DATABASE_URL=postgresql://dofe:password@127.0.0.1:5432/vibecoding_dofe?schema=public&timezone=Asia/Shanghai

REDIS_URL=redis://:password@127.0.0.1:6379/2

RABBITMQ_URL=amqp://dofe:password@127.0.0.1:5672/vibecoding_dofe
RABBITMQ_OPTIONAL=true

# ============================================
# Secrets
# ============================================
# Core secrets should live in apps/api/keys/config.json when running this app.
# main.ts syncs the following keys into process.env before initConfig():
#   JWT_SECRET / JWT_EXPIRE_IN / CRYPTO_KEY / CRYPTO_IV / ENCRYPTION_KEY
#
# Example keys/config.json:
# {
#   "jwt": { "secret": "replace-me", "expireIn": 86400 },
#   "crypto": { "key": "32-char-key", "iv": "16-char-iv" },
#   "encryption": { "key": "replace-me" }
# }

# ============================================
# SSO / OIDC
# ============================================
SSO_API_URL=http://127.0.0.1:3100
SSO_INTERNAL_API_URL=http://127.0.0.1:3100
SSO_ISSUER=http://127.0.0.1:3100
SSO_CLIENT_ID=vibecoding-dofe-ai
SSO_CLIENT_SECRET=your-vibecoding-client-secret-from-sso
SSO_SERVICE_NAME=vibecoding.dofe.ai
INTERNAL_API_SECRET=your-internal-api-secret-from-sso

# Optional: set to 1 only for local/test SSO with self-signed certificates.
# SSO_ALLOW_INSECURE_TLS=0

# Optional OIDC/JWKS overrides. Usually discovered from SSO_ISSUER.
# SSO_DISCOVERY_URL=http://127.0.0.1:3100/.well-known/openid-configuration
# JWKS_PATH=/oauth/jwks
# JWKS_URI=http://127.0.0.1:3100/oauth/jwks
# INTERNAL_JWKS_URI=http://127.0.0.1:3100/oauth/jwks

# ============================================
# Local auth bypass / preview mode
# ============================================
# Never enable MODE_USER_ID in production.
# MODE_USER_ID=
# PREVIEW_MODE=false
# PREVIEW_USER_ID=

# ============================================
# Loops automation
# ============================================
# LOOPS_WORKSPACE_ROOT=/absolute/path/to/workspace
# LOOPS_ALLOWED_REPO_ROOTS=/absolute/path/to/workspace
# LOOPS_AGENT_MODE=deterministic
# LOOPS_GIT_BASE_BRANCH=main
# LOOPS_GIT_COMMIT_PER_SHARD=false
# LOOPS_RUNTIME_DETECT_TIMEOUT_MS=5000

# Webhook ingestion.
# LOOPS_WEBHOOK_SECRET=replace-me
# LOOPS_GITHUB_WEBHOOK_SECRET=replace-me
# LOOPS_WEBHOOK_MAX_PAYLOAD_BYTES=65536
# LOOPS_WEBHOOK_RATE_LIMIT_PER_MINUTE=60

# Pull request publishing. Set either LOOPS_PR_TOKEN or GitHub App credentials.
# LOOPS_PR_PROVIDER=github
# LOOPS_PR_API_BASE_URL=https://api.github.com
# LOOPS_PR_REPOSITORY=owner/repo
# LOOPS_PR_REPOSITORY_ALLOWLIST=owner/repo
# LOOPS_PR_TOKEN=
# LOOPS_PR_TOKEN_SECRET_REF=LOOPS_PR_TOKEN
# LOOPS_GITHUB_APP_ID=
# LOOPS_GITHUB_APP_INSTALLATION_ID=
# LOOPS_GITHUB_APP_PRIVATE_KEY=
# LOOPS_GITHUB_APP_PRIVATE_KEY_SECRET_REF=LOOPS_GITHUB_APP_PRIVATE_KEY

# Notifications.
# LOOPS_ALERT_WEBHOOK_URL=
# LOOPS_ALERT_WEBHOOK_TOKEN=
# LOOPS_FEISHU_WEBHOOK_URL=
# LOOPS_FEISHU_WEBHOOK_TOKEN=

# Docker runtime for private agent images.
# DOCKER_HOST=/var/run/docker.sock
# DOCKER_REGISTRY_SERVER=
# DOCKER_REGISTRY_USERNAME=
# DOCKER_REGISTRY_PASSWORD=

# ============================================
# External services
# ============================================
# ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_secret

# VOLCENGINE_ACCESS_KEY=your_access_key
# VOLCENGINE_SECRET_KEY=your_secret_key

# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your_bucket
